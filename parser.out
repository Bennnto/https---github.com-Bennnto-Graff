Rule 25    type -> INT_TYPE
Rule 26    type -> STR_TYPE
Rule 27    statement -> LET ID COLON type ASSIGN expression optional_semicolon
Rule 28    empty -> <empty>
Rule 29    optional_semicolon -> SEMICOLON
Rule 30    optional_semicolon -> empty

